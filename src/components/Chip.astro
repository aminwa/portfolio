---
interface Props {
  label: string;
  mono?: boolean;
}
const { label, mono = false } = Astro.props;
---

<span
  style={`display:inline-flex;align-items:center;padding:0.25rem 0.625rem;font-size:0.72rem;border-radius:0.375rem;background:var(--bg-2);border:1px solid var(--border);color:var(--fg-2);${mono ? 'font-family:var(--font-mono,monospace);' : ''}`}
>
  {label}
</span>
