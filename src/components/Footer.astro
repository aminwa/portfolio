---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer style="border-top:1px solid var(--border);padding:2.5rem 0;">
  <div style="max-width:var(--max-width-content,1280px);margin:0 auto;padding:0 2rem;">
    <div style="display:flex;flex-direction:column;gap:0.75rem;align-items:center;justify-content:space-between;" class="footer-inner">
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;justify-content:center;font-size:0.7rem;color:var(--fg-2);font-family:var(--font-mono,monospace);">
        <span>© {year} {site.name}</span>
        <span style="opacity:0.3;">·</span>
        <span>BSc Computer Science · University of Derby</span>
      </div>
      <a href="#hero"
         style="font-family:var(--font-mono,monospace);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--fg-2);text-decoration:none;transition:color 0.15s;display:flex;align-items:center;gap:0.5rem;"
         aria-label="Back to top"
         onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--fg-2)'">
        ↑ Back to top
      </a>
    </div>
  </div>
</footer>

<style>
  @media (min-width: 640px) {
    .footer-inner { flex-direction: row !important; align-items: center !important; }
  }
</style>
