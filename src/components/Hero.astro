---
import { site } from '../data/site';
import HeroScene from './HeroScene';
---

<section
  id="hero"
  aria-label="Introduction"
  style="position:relative;min-height:100vh;display:grid;align-items:center;padding-top:3.5rem;overflow:hidden;"
>
  <!-- Three.js scene -->
  <HeroScene client:only="react" />

  <!-- Radial glow behind sphere (right side) -->
  <div aria-hidden="true" style="position:absolute;right:-5%;top:10%;width:55%;aspect-ratio:1;border-radius:50%;background:radial-gradient(ellipse,rgba(201,162,39,0.08) 0%,transparent 70%);pointer-events:none;z-index:1;"></div>

  <!-- Left gradient mask so text is always readable -->
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(95deg,var(--hero-fade) 38%,var(--hero-fade-mid) 62%,transparent 80%);pointer-events:none;z-index:1;"></div>

  <!-- Content (z-index:2) -->
  <div style="position:relative;z-index:2;max-width:var(--max-width-content,1280px);margin:0 auto;padding:5rem 2rem 8rem;width:100%;">
    <div style="max-width:38rem;">

      <!-- Eyebrow -->
      <div data-hero="eye" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:2rem;opacity:0;transform:translateY(12px);">
        <span style="display:block;width:2rem;height:1px;background:var(--accent);"></span>
        <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:var(--accent);letter-spacing:0.2em;text-transform:uppercase;">Portfolio · 2026</span>
      </div>

      <!-- Name — GSAP splits this into chars -->
      <h1
        data-hero="name"
        style="font-size:clamp(3.5rem,8vw,6.5rem);font-weight:700;color:var(--fg);letter-spacing:-0.03em;margin:0 0 0.5rem;line-height:1.0;overflow:hidden;"
      >
        {site.name}
      </h1>

      <!-- Role — sliding underline accent -->
      <div data-hero="role" style="margin:0 0 2rem;opacity:0;transform:translateX(-20px);">
        <p style="font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:400;color:var(--accent);line-height:1.3;">
          {site.role}
        </p>
        <div style="width:3.5rem;height:2px;background:var(--accent);margin-top:0.75rem;border-radius:1px;"></div>
      </div>

      <!-- Tagline -->
      <p
        data-hero="tag"
        style="font-size:1rem;color:var(--fg-2);max-width:36rem;line-height:1.75;margin:0 0 2.5rem;opacity:0;"
      >
        {site.tagline}
      </p>

      <!-- Cycling mono line -->
      <p
        id="hero-tagline"
        aria-live="polite"
        data-hero="mono"
        style="font-family:var(--font-mono,monospace);font-size:0.8rem;color:var(--accent);opacity:0;margin:0 0 2.5rem;letter-spacing:0.05em;"
      >
        {site.taglines[0]}
      </p>

      <!-- CTAs -->
      <div data-hero="ctas" style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:3rem;opacity:0;transform:translateY(12px);">
        <a
          href="#projects"
          class="btn-magnetic"
          style="display:inline-flex;align-items:center;gap:0.625rem;padding:0.75rem 1.75rem;background:var(--accent);color:var(--on-accent);font-weight:600;font-size:0.875rem;border-radius:0.375rem;text-decoration:none;letter-spacing:0.01em;transition:filter 0.2s,transform 0.2s;"
          onmouseover="this.style.filter='brightness(1.1)'"
          onmouseout="this.style.filter='brightness(1)'"
        >
          View projects
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href="#contact"
          class="btn-magnetic"
          style="display:inline-flex;align-items:center;gap:0.625rem;padding:0.75rem 1.75rem;border:1px solid var(--border-acc);color:var(--fg);font-weight:500;font-size:0.875rem;border-radius:0.375rem;text-decoration:none;transition:border-color 0.2s,color 0.2s;"
          onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'"
          onmouseout="this.style.borderColor='var(--border-acc)';this.style.color='var(--fg)'"
        >
          Get in touch
        </a>
      </div>

      <!-- Social + location -->
      <div data-hero="foot" style="display:flex;align-items:center;gap:1.5rem;opacity:0;">
        <a href={site.socials.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub"
           style="color:var(--fg-2);transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-2)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
        </a>
        <a href={site.socials.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
           style="color:var(--fg-2);transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-2)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <span style="width:1px;height:1rem;background:var(--border);"></span>
        <span style="font-family:var(--font-mono,monospace);font-size:0.7rem;color:var(--fg-2);letter-spacing:0.05em;">{site.location}</span>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    aria-hidden="true"
    style="position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;z-index:2;"
  >
    <span style="font-family:var(--font-mono,monospace);font-size:0.65rem;color:var(--fg-2);letter-spacing:0.15em;text-transform:uppercase;">scroll</span>
    <div style="width:1px;height:2.5rem;background:linear-gradient(to bottom,var(--accent),transparent);animation:fadeIn 1s ease 3s both;"></div>
  </div>
</section>

<script>
  // Cycling tagline
  const lines = ['YOLOv8 · spaCy · on-device LLMs', 'shell-pilot · screenshield · redact', 'GDPR + LLMs: a structural mismatch', 'mirror-game · mocap · formal proofs'];
  const el = document.getElementById('hero-tagline') as HTMLElement | null;
  if (el && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    el.style.transition = 'opacity 0.25s ease';
    setInterval(() => {
      i = (i + 1) % lines.length;
      el.style.opacity = '0';
      setTimeout(() => { el.textContent = lines[i]; el.style.opacity = '1'; }, 260);
    }, 3500);
  }
</script>
