---
import { moreProjects } from '../data/projects';
---

<div style="display:flex;flex-direction:column;gap:0;">
  {moreProjects.map((project, i) => (
    <details class="more-item" style={`border-bottom:1px solid var(--border);${i === 0 ? 'border-top:1px solid var(--border);' : ''}`}>
      <summary
        style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.25rem 0;cursor:pointer;list-style:none;user-select:none;"
      >
        <div style="display:flex;align-items:center;gap:1.25rem;flex:1;min-width:0;">
          <span style="font-family:var(--font-mono,monospace);font-size:0.65rem;color:var(--accent);opacity:0.6;flex-shrink:0;letter-spacing:0.1em;">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
              <h3 class="more-title" style="font-size:0.9375rem;font-weight:600;color:var(--fg);margin:0;transition:color 0.15s;">{project.title}</h3>
              <span style="font-size:0.65rem;padding:0.15rem 0.5rem;border-radius:9999px;border:1px solid var(--border);color:var(--fg-2);font-family:var(--font-mono,monospace);white-space:nowrap;flex-shrink:0;">
                {project.category}
              </span>
            </div>
            <p style="font-size:0.825rem;color:var(--fg-2);margin:0.25rem 0 0;line-height:1.5;">{project.summary}</p>
          </div>
        </div>
        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"
          style="flex-shrink:0;color:var(--fg-2);transition:transform 0.25s ease;">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>

      <div style="padding:0 0 1.5rem;">
        <div style="padding:1.25rem;background:var(--bg-1);border-radius:0.75rem;border:1px solid var(--border);">
          <ul style="margin:0 0 1rem;padding:0;list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
            {project.highlights.map((h) => (
              <li style="display:flex;gap:0.75rem;font-size:0.85rem;color:var(--fg-2);line-height:1.6;">
                <span style="color:var(--accent);flex-shrink:0;font-family:var(--font-mono,monospace);">—</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
          <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:1rem;">
            {project.tech.map((t) => (
              <span style="font-size:0.7rem;font-family:var(--font-mono,monospace);padding:0.2rem 0.5rem;border-radius:0.25rem;background:var(--bg-2);border:1px solid var(--border);color:var(--fg-2);">{t}</span>
            ))}
          </div>
          {project.links && project.links.length > 0 && (
            <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
              {project.links.map((link) => {
                const isFill = link.href === '[[FILL]]';
                return (
                  <a
                    href={isFill ? '#' : link.href}
                    style={`font-size:0.75rem;font-weight:500;text-decoration:none;padding:0.375rem 0.75rem;border-radius:0.375rem;border:1px solid;transition:background 0.15s,color 0.15s;${isFill ? 'border-color:var(--border);color:var(--fg-2);opacity:0.5;cursor:not-allowed;pointer-events:none;' : 'border-color:var(--border-acc);color:var(--accent);'}`}
                    {...(!isFill ? { target: '_blank', rel: 'noopener noreferrer' } : { 'aria-disabled': 'true' })}
                    onmouseover={isFill ? undefined : "this.style.background='var(--accent)';this.style.color='var(--bg)'"}
                    onmouseout={isFill ? undefined : "this.style.background='transparent';this.style.color='var(--accent)'"}
                  >
                    {link.label}
                    {isFill && <span style="font-size:0.65rem;opacity:0.6;margin-left:0.25rem;">[[FILL]]</span>}
                  </a>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </details>
  ))}
</div>

<style>
  details[open] .chevron { transform: rotate(180deg); }
  .more-item summary:hover .more-title { color: var(--accent); }
  .more-item summary { outline: none; }
  .more-item summary:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 0.25rem; }
</style>
