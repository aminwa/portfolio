---
import { site } from '../data/site';
import ThemeToggle from './ThemeToggle';
import CommandPalette from './CommandPalette';
---

<header id="site-header" style="position:fixed;top:0;left:0;right:0;z-index:40;transition:background 0.3s,border-color 0.3s,backdrop-filter 0.3s;">
  <nav
    style="max-width:var(--max-width-content,1280px);margin:0 auto;padding:0 2rem;height:3.5rem;display:flex;align-items:center;justify-content:space-between;"
    aria-label="Main navigation"
  >
    <a
      href="/"
      style="font-family:var(--font-mono,monospace);font-size:0.875rem;font-weight:700;color:var(--fg);text-decoration:none;letter-spacing:0.05em;transition:color 0.15s;"
      onmouseover="this.style.color='var(--accent)'"
      onmouseout="this.style.color='var(--fg)'"
      aria-label="Amin Wafi — home"
    >
      AW
    </a>

    <!-- Desktop links -->
    <ul class="desktop-nav" style="display:none;align-items:center;gap:1.75rem;list-style:none;" role="list">
      {site.navItems.map((item) => (
        <li>
          <a
            href={item.href}
            style="font-size:0.8rem;font-weight:400;color:var(--fg-2);text-decoration:none;letter-spacing:0.02em;transition:color 0.15s;"
            onmouseover="this.style.color='var(--fg)'"
            onmouseout="this.style.color='var(--fg-2)'"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div style="display:flex;align-items:center;gap:0.5rem;">
      <CommandPalette client:load />
      <ThemeToggle client:load />
      <a
        href="/amin-wafi-cv.pdf"
        class="resume-btn"
        style="display:none;align-items:center;padding:0.375rem 0.875rem;font-size:0.8rem;font-weight:500;border:1px solid var(--border-acc);color:var(--accent);border-radius:0.375rem;text-decoration:none;letter-spacing:0.02em;transition:background 0.2s,color 0.2s;"
        target="_blank" rel="noopener noreferrer"
        onmouseover="this.style.background='var(--accent)';this.style.color='var(--bg)'"
        onmouseout="this.style.background='transparent';this.style.color='var(--accent)'"
      >
        Résumé
      </a>

      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        class="mobile-btn"
        style="padding:0.5rem;color:var(--fg-2);background:transparent;border:none;cursor:pointer;"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;border-top:1px solid var(--border);background:var(--bg);">
    <ul style="padding:1rem 2rem;display:flex;flex-direction:column;gap:0.25rem;list-style:none;" role="list">
      {site.navItems.map((item) => (
        <li>
          <a href={item.href} class="mobile-nav-link"
             style="display:block;padding:0.625rem 0;font-size:0.875rem;color:var(--fg-2);text-decoration:none;border-bottom:1px solid var(--border);">
            {item.label}
          </a>
        </li>
      ))}
      <li style="padding-top:0.5rem;">
        <a href="/amin-wafi-cv.pdf" target="_blank" rel="noopener noreferrer"
           style="display:block;padding:0.625rem 0;font-size:0.875rem;font-weight:500;color:var(--accent);text-decoration:none;">
          Résumé (PDF) ↗
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    .desktop-nav { display: flex !important; }
    .resume-btn  { display: flex !important; }
    .mobile-btn  { display: none !important; }
  }
</style>

<script>
  // Scroll-aware nav styling
  const header = document.getElementById('site-header')!;
  const update = () => {
    const scrolled = window.scrollY > 40;
    header.style.background = scrolled ? 'color-mix(in srgb,var(--bg) 85%,transparent)' : 'transparent';
    header.style.backdropFilter = scrolled ? 'blur(16px) saturate(1.4)' : 'none';
    header.style.borderBottom = scrolled ? '1px solid var(--border)' : '1px solid transparent';
  };
  window.addEventListener('scroll', update, { passive: true });
  update();

  // Mobile menu
  const btn  = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => {
    const open = menu.style.display !== 'none';
    menu.style.display = open ? 'none' : 'block';
    btn.setAttribute('aria-expanded', String(!open));
  });
  document.querySelectorAll('.mobile-nav-link').forEach((l) =>
    l.addEventListener('click', () => { menu.style.display = 'none'; btn.setAttribute('aria-expanded','false'); })
  );
</script>
