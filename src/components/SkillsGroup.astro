---
import { skillGroups } from '../data/skills';
---

<div style="display:grid;gap:2.5rem;" class="skills-outer">
  {skillGroups.map((group) => (
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div style="display:flex;align-items:center;gap:0.75rem;">
        <span style="display:block;width:1.5rem;height:1px;background:var(--accent);opacity:0.5;"></span>
        <h3 style="font-family:var(--font-mono,monospace);font-size:0.65rem;color:var(--fg-2);letter-spacing:0.2em;text-transform:uppercase;margin:0;">
          {group.label}
        </h3>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {group.skills.map((skill) => (
          <span style="display:inline-flex;align-items:center;padding:0.3rem 0.75rem;font-size:0.75rem;font-family:var(--font-mono,monospace);border-radius:0.375rem;background:var(--bg-2);border:1px solid var(--border);color:var(--fg-2);transition:border-color 0.15s,color 0.15s;cursor:default;"
            onmouseover="this.style.borderColor='var(--border-acc)';this.style.color='var(--accent)'"
            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--fg-2)'"
          >
            {skill}
          </span>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  @media (min-width: 768px) {
    .skills-outer { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .skills-outer { grid-template-columns: repeat(3, 1fr); }
  }
</style>
